    "version": "refactor_ecommerce_v1",
    "timezone": "Europe/Paris",
    "scope": "Meow Paw Paw O.S. — accounting parameters only",
    "notes": [
      "Stable accounting conventions and source map only.",
      "No ledger lines, no ops logs, no moving values, no detailed tariff duplication."
    ],
    "updated_at": "2026-05-12"
  },
  "accounting_scope": {
    "legal_structure": "SASU",
    "legal_entity_name": "TRADE-VISION",
    "country": "FR",
    "tax_regime": "IS",
    "sales_price_mode": "TTC",
    "vat_mode": "disabled_at_launch",
    "packaging_cost_model": "embedded_in_supplier_quote"
  },
  "status_conventions": {
    "amount_status_allowed": [
      "confirmed",
      "estimated",
      "to_be_reconciled"
    ],
    "missing_value_status": "unavailable",
    "reporting_rule": "Never present a numeric readout as confirmed if it is not traceable to a declared source."
  },
