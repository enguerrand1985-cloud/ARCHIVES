    "actual_total_eur": 87.69,
    "source_of_truth": {
      "file": "PARAMETERS/PROFIL_SASU.json",
      "legacy_file": "data__owner_profile.json",
      "json_path": "/identity/budget_and_storage/fixed_costs_actual_current"
    }
  },
  "margin_modes": {
    "cash_now": {
      "purpose": "Pilotage de la realite immediate et de la tresorerie avant activite Amazon stable.",
      "include_inputs": [
        "sales_price_mode",
        "fixed_costs_monthly_base",
        "is_rate",
        "vat_sales_rate",
        "vat_purchases_rate",
        "vat_recovery_ratio",
        "include_tva_in_margins"
      ],
      "include_policies_when_active": [
        "ppc_policy"
      ],
      "exclude_until_real_activity": [
        "referral_fee_policy",
        "fba_fee_policy",
        "dsf_policy"
      ],
      "notes": [
        "Ne pas compter les frais Amazon tant qu'il n'y a pas de vente ou de facturation Amazon reelle.",
        "Le PPC reste a zero tant qu'aucune campagne n'est activee."
      ]
    },
    "unit_economics_launch": {
      "purpose": "Tester la viabilite economique d'une vente Amazon des le lancement.",
      "include_inputs": [
        "sales_price_mode",
        "sales_price_canon",
        "sales_currency",
        "sales_channel",
        "supplier_unit_cost",
        "packaging_cost_mode",
        "launch_shipping_policy",
        "fixed_costs_monthly_base",
        "referral_fee_policy",
        "fba_fee_policy",
        "dsf_policy",
        "is_rate",
        "vat_sales_rate",
        "vat_purchases_rate",
        "vat_recovery_ratio",
        "include_tva_in_margins"
      ],
      "include_policies_when_active": [
        "ppc_policy"
      ],
      "notes": [
        "Vue recommandee pour estimer la marge par SKU avant mise en ligne.",
        "Le PPC doit etre ajoute seulement si une strategie d'acquisition payante est retenue."
      ]
    },
    "scale_scenario": {
      "purpose": "Scenario prudent pour evaluer une marge sous contraintes plus completes.",
      "include_inputs": [
        "sales_price_mode",
        "sales_price_canon",
        "sales_currency",
        "sales_channel",
        "supplier_unit_cost",
        "packaging_cost_mode",
        "launch_shipping_policy",
        "fixed_costs_monthly_base",
        "referral_fee_policy",
        "fba_fee_policy",
        "ppc_policy",
        "dsf_policy",
        "trade_assurance_policy",
        "card_processing_policy",
        "fx_policy",
        "is_rate",
        "vat_sales_rate",
        "vat_purchases_rate",
        "vat_recovery_ratio",
        "include_tva_in_margins"
      ],
      "notes": [
        "Vue de stress test pour anticiper une structure de couts plus complete.",
        "Ne pas presenter cette vue comme marge reelle du moment."
      ]
    }
  },
  "margin_execution_policy": {
    "default_margin_mode": "unit_economics_launch",
    "default_sku_selection": {
      "launch_scope": true,
      "status_equals": "ready",
      "notes": [
        "Ne calculer par defaut que les SKU explicitement retenus pour le lancement.",
        "Ne pas inclure les SKU hors scope ou non prets dans une moyenne ou un total de lancement."
      ]
    },
    "fba_fee_resolution": {
      "packaged_specs_source": "packaged_specs_truth",
      "require_confirmed_measurements": true,
      "fallback_behavior": "stop_and_flag_missing_packaged_specs",
      "notes": [
        "Le bareme FBA ne doit pas etre applique si les dimensions ou le poids colis ne sont pas confirmes.",
        "Si packaged_specs_truth manque, la sortie doit rester non calculee et expliciter la donnee manquante."
      ]
    },
    "fixed_cost_allocation": {
      "allocation_basis": "monthly_units_sold_scenario",
      "default_monthly_units_sold": 60,
      "allowed_monthly_units_sold_scenarios": [
        30,
        60,
        90
      ],
      "notes": [
        "Les frais fixes ne doivent jamais etre repartis sur le stock ou sur les unites produites.",
        "La repartition se fait sur un scenario de ventes mensuelles explicite."
      ]
    },
    "tax_projection": {
      "apply_is_only_if_positive_after_fixed_costs": true,
      "computation_base": "margin_after_variable_costs_and_fixed_cost_allocation",
      "negative_margin_behavior": "set_is_projection_to_zero",
      "notes": [
        "L'estimatif apres IS est une projection et ne doit pas etre presente comme un flux reel.",
        "Ne jamais appliquer l'IS sur une marge negative ou avant allocation des frais fixes si la vue inclut ces frais."
      ]
    },
    "uncertainty_contract": {
      "label_output_as_estimated_if_any_input_not_confirmed": true,
      "require_explicit_assumptions_section": true,
      "stop_if_sales_price_missing": true,
      "stop_if_supplier_cost_missing": true,
      "stop_if_required_fee_policy_missing": true,
      "notes": [
        "Toute sortie doit separer clairement les donnees confirmees et estimees.",
        "Si un input critique manque, il faut stopper le calcul plutot qu'inventer une valeur."
      ]
    }
  },
  "marketplace_conventions": {
    "currency_default": "EUR",
    "sales_channel_canon": "amazon_fba",
    "effective_from_required_when_applicable": true,
    "amount_status_allowed": [
      "confirmed",
