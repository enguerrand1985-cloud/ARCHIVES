    "policies": [
      {
        "id": "POLICY__SCOPE_CLOSED_BY_DEFAULT",
        "title": "Scope fermé par défaut",
        "description": "Sans demande explicite, pas d’inférence cross-scope. Toute agrégation cross-scope doit être explicitement demandée.",
        "enabled": true
      },
      {
        "id": "POLICY__ARCHIVES_NOT_CANONICAL",
        "title": "Archives non-canoniques",
        "description": "Les archives ne sont jamais une source de vérité si une donnée canonique existe. Lecture des archives uniquement sur demande explicite.",
        "enabled": true
      },
      {
        "id": "POLICY__CANONIQUE_CLEAN_NO_EVIDENCE_KEYS",
        "title": "Canonique propre (pas de preuves/sources)",
        "description": "Interdiction globale des clés de provenance/preuve (sources, evidence, source_ref, extraction, etc.). Le fichier déclare les faits.",
        "enabled": true
      },
      {
        "id": "POLICY__SENSITIVE_DATA_NO_SECRETS",
        "title": "Données sensibles: pas de secrets",
        "description": "Les secrets d'authentification (CVV, mots de passe, codes 2FA) ne sont jamais stockés. Utiliser value=null + policy='masked_not_stored' si besoin.",
        "enabled": true
      },
      {
        "id": "POLICY__MAINTENANCE_MODE",
        "title": "Maintenance contrôlée",
        "description": "Doctrine MAINTENANCE: une IA peut proposer des modifications d'un fichier de scope uniquement sur instruction explicite de l'utilisateur (ex: 'mets à jour la fiche').",
        "enabled": true
      },
      {
        "id": "POLICY__UPDATE_OUTPUT_MODES",
        "title": "Modes de sortie d’update",
        "description": "Objectif: permettre des mises à jour multi-IA (Copilot, GPT, Claude, Gemini, etc.) avec des sorties JSON exploitables.",
        "enabled": true
      },
      {
        "id": "POLICY__DEPENDENCY_POINTERS",
        "title": "Pointeurs de dépendances",
        "description": "Les dépendances entre data, règles moteur, et todo sont exprimées via des pointeurs stables (IDs).",
        "enabled": true
      },
      {
        "id": "POLICY__OVERWRITE_BY_ID",
        "title": "Overwrite in-place par id",
        "description": "Politique d'overwrite: une mise à jour d'une entité canonique se fait par remplacement des champs sur le même id (overwrite in-place). Interdiction de suppression d'entités canoniques en maintenance standard: préférer l'overwrite sur id existant pour refléter le nouvel état sans conserver d'ancienne occurrence.",
        "enabled": true
      }
    ],
    "playbooks": [
      {
        "id": "PLAYBOOK__ONBOARDING",
        "title": "Onboarding / compréhension du fichier",
        "steps": [
          "Lire meta",
          "Lire scope_header",
          "Lire llm_contract (policies + playbooks)",
          "Lire mini_index (navigation)",
          "Lire regles_metier.rules_engine (si objectif action/calcul)",
          "Lire data.canonique (faits)",
          "Ne lire data.scope_specifique.archives que sur demande explicite"
        ]
      },
      {
        "id": "PLAYBOOK__DATA_LOOKUP",
        "title": "Recherche factuelle",
        "steps": [
          "Lire data.canonique en priorité",
          "Utiliser documents_index pour trouver les pièces",
          "Ignorer archives sauf demande explicite"
        ]
      },
      {
        "id": "PLAYBOOK__MAINTENANCE",
        "title": "Maintenance / mise à jour contrôlée",
        "steps": [
          "Vérifier instruction explicite de mise à jour (sinon rester en lecture/planification)",
          "Appliquer triage (ingestion): identifier faits à mettre à jour, demander les infos manquantes si nécessaire",
          "Mettre à jour data.canonique par overwrite in-place (match par id), sans suppression",
          "Rebuild contrôlé de todo: régénérer/ajuster les tâches liées via links et/ou rule_id; appliquer rollover recurring si applicable",
          "Produire une sortie JSON exploitable (MERGE_PATCH par défaut) + demander validation utilisateur"
        ]
      },
      {
        "id": "PLAYBOOK__OUTPUT_JSON",
        "title": "Sortie JSON exploitable (update)",
        "steps": [
          "Choisir le mode de sortie: MERGE_PATCH_RFC7396 (défaut) / FULL_REPLACE (fallback) / PATCH_RFC6902 (avancé)",
          "Produire un bloc JSON unique sans prose mélangée",
          "Inclure mode, target_filename, scope, payload"
        ]
      },
      {
        "id": "PLAYBOOK__REBUILD_TODO",
        "title": "Rebuild contrôlé de todo",
        "steps": [
          "Identifier les entités canoniques modifiées (ids)",
          "Retrouver les tâches todo impactées via links (ref_id) et/ou rule_id",
          "Mettre à jour/remplacer les tâches concernées; conserver les autres",
          "Appliquer la règle de rollover pour recurring (DONE ⇒ next_run_at recalculé ⇒ PLANNED)"
        ]
      }
    ],
    "hints": [
      "Fiche LLM autonome. Respecte strictement le schéma. Scope fermé par défaut: pas d’inférence ou fusion cross-scope sans demande explicite. data.canonique est la source de vérité; archives non canoniques (lecture sur demande). Ne jamais inventer de valeurs absentes. Ne jamais stocker de secrets (CVV/mdp/2FA). Mises à jour uniquement sur instruction explicite + validation: overwrite in-place par id (pas de suppression) et rebuild contrôlé de todo via rule_id et todo.links (liens vers ids canoniques, jamais cross-scope). Sortie obligatoire en JSON exploitable: MERGE_PATCH par défaut, fallback FULL_REPLACE si nécessaire.",
      ""
    ]
  },
