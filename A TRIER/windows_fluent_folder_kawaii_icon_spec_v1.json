{
  "meta": {
    "schema": "windows_fluent_folder_kawaii_icon_spec_v1",
    "version": "1.0.0",
    "description": "Configuration de génération pour icônes de dossier Windows Fluent réalistes avec motif kawaii centré.",
    "authoring_mode": "reproducible_visual_spec",
    "language": "fr"
  },
  "global_style": {
    "design_language": "Windows Fluent UI",
    "platform_target": "Windows 11",
    "icon_family": "custom folder shortcuts",
    "primary_aesthetic": "realistic fluent folder with centered kawaii motif",
    "look_and_feel": {
      "minimal": true,
      "clean": true,
      "soft_depth": true,
      "realistic_folder": true,
      "kawaii_centerpiece": true,
      "cartoon_background": false,
      "neon": false,
      "overdecorated": false,
      "flat_only": false,
      "aggressive_3d": false
    }
  },
  "canvas": {
    "aspect_ratio": "1:1",
    "working_size_px": 1024,
    "background": {
      "type": "transparent",
      "checkerboard_visible": false,
      "solid_fill": null
    },
    "export": {
      "png_transparent": true,
      "ico": {
        "enabled": true,
        "sizes_px": [
          256,
          128,
          64,
          48,
          32,
          16
        ]
      }
    }
  },
  "folder_base": {
    "type": "windows_folder_modern_realistic",
    "shape": {
      "corner_radius_px": 42,
      "top_tab": true,
      "tab_alignment": "left",
      "tab_softness": "rounded",
      "front_plate_ratio": 0.84
    },
    "perspective": {
      "mode": "front_soft",
      "tilt_degrees": 0,
      "distortion": "very_low"
    },
    "surface": {
      "finish": "soft_matte",
      "micro_texture": "very_subtle",
      "gloss": "low"
    },
    "depth": {
      "front_plate_layer": true,
      "back_plate_layer": true,
      "layer_separation_px": 14,
      "shadow_softness": "medium",
      "shadow_opacity": 0.18
    },
    "outline": {
      "enabled": false,
      "hard_stroke": false
    }
  },
  "lighting": {
    "style": "soft_studio",
    "top_highlight": true,
    "rim_light": false,
    "light_direction": "top_left",
    "contrast": "medium_low",
    "bloom": false
  },
  "composition": {
    "subject_alignment": "center",
    "kawaii_alignment": "center",
    "safe_margin_ratio": 0.12,
    "motif_scale_ratio": 0.4,
    "motif_vertical_offset_ratio": 0.01,
    "balance": "centered",
    "readability_at_small_size": {
      "priority": "high",
      "max_detail_level": "medium_low",
      "thin_lines_allowed": false,
      "min_stroke_px_at_1024": 24
    }
  },
  "style_reference": {
    "folder_style_ref": {
      "name": "Windows Fluent Folder Realistic",
      "keywords": [
        "Windows 11 folder",
        "Fluent UI",
        "realistic modern folder",
        "soft gradient",
        "rounded corners",
        "subtle depth",
        "clean icon"
      ]
    },
    "kawaii_style_ref": {
      "name": "Kawaii mascot sticker illustration",
      "keywords": [
        "kawaii",
        "cute mascot",
        "soft rounded shapes",
        "friendly face",
        "pastel-friendly palette",
        "clean cartoon lines",
        "adorable centered motif",
        "sticker-like subject"
      ],
      "facial_rules": {
        "eyes": "simple and expressive",
        "mouth": "small friendly smile",
        "blush": "optional",
        "emotion": "cute, warm, readable"
      }
    }
  },
  "color_system": {
    "folder_fill_mode": "solid_gradient_soft",
    "folder_palettes": {
      "beige_yellow": {
        "base": "#EACB94",
        "shadow": "#C89F63",
        "highlight": "#F8E7C2"
      },
      "gray": {
        "base": "#D7DCE4",
        "shadow": "#A8B0BC",
        "highlight": "#F2F5F8"
      },
      "turquoise_blue": {
        "base": "#64DFF1",
        "shadow": "#2EAFE2",
        "highlight": "#BDF7FF"
      },
      "purple": {
        "base": "#B06CFF",
        "shadow": "#7B3FE3",
        "highlight": "#E0B8FF"
      }
    }
  },
  "center_motif_rules": {
    "type": "kawaii_central_visual",
    "placement": "centered_on_front_plate",
    "rendering": {
      "mode": "clean_illustrated_sticker",
      "edge_definition": "soft_clean_outline",
      "shadow": "subtle",
      "outline": "optional_soft",
      "floating_effect": "slight"
    },
    "allowed_subjects": [
      "kawaii mascot",
      "cute animal",
      "cute object",
      "cute logo reinterpretation",
      "group photo style kawaii composition"
    ],
    "forbidden_subjects": [
      "hyper realistic portrait",
      "busy background scene",
      "tiny unreadable text",
      "photographic clutter"
    ]
  },
  "prompt_rules": {
    "must_include": [
      "transparent background",
      "Windows 11 Fluent UI realistic folder",
      "centered kawaii motif",
      "motif placed in the middle of the folder",
      "soft gradients",
      "rounded corners",
      "clean modern icon",
      "no checkerboard visible",
      "no watermark",
      "square composition"
    ],
    "must_avoid": [
      "black background",
      "dark studio backdrop",
      "visible transparency grid",
      "neon glow",
      "busy composition",
      "text labels",
      "overly realistic skin textures",
      "too many tiny details"
    ]
  },
  "postprocess": {
    "remove_background": true,
    "alpha_cleanup": true,
    "crop_to_visible_bounds": true,
    "recenter_on_square_canvas": true,
    "preserve_transparency": true,
    "ico_generate": true
  },
  "template_variant": {
    "name": "onedrive_pro_beige_kawaii_center",
    "folder_palette": "beige_yellow",
    "motif": {
      "style_ref": "Kawaii mascot sticker illustration",
      "placement": "center",
      "scale_ratio": 0.4,
      "example_uses": [
        "dashboard mascot pointing at board",
        "comptabilité with kawaii paw and finance elements",
        "édition with kawaii group photo"
      ]
    }
  }
}